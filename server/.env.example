# ── Onshape credentials (choose one method) ──────────────────────────────────
# Method 1: API Keys (recommended for personal/internal use)
ONSHAPE_ACCESS_KEY=your_onshape_access_key
ONSHAPE_SECRET_KEY=your_onshape_secret_key

# Method 2: OAuth access token
# ONSHAPE_ACCESS_TOKEN=your_oauth_token

# ── AI Provider keys (configure at least one) ─────────────────────────────────
# GitHub Copilot / GitHub Models (https://github.com/settings/tokens)
GITHUB_TOKEN=your_github_token

# OpenAI
# OPENAI_API_KEY=your_openai_key

# Anthropic
# ANTHROPIC_API_KEY=your_anthropic_key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed origins for CORS (defaults to * if not set)
# ALLOWED_ORIGINS=http://localhost:5173,https://your-onshape-app.example.com
